# ── Backend Configuration ──
PORT=5000
DB_URL=mongodb://localhost:27017/mydb
SECRET_KEY=abc123

# ── OPTIONAL — improves rate limits, all free to register ──

# PubMed/NCBI — free at https://ncbi.nlm.nih.gov/account
# Without key: 3 req/sec  |  With key: 10 req/sec
NCBI_API_KEY=

# The Guardian News — free at https://open-platform.theguardian.com
# Without key (use "test"): 12 req/day  |  With key: 500 req/day
GUARDIAN_API_KEY=

# OpenFDA and Wikipedia need NO key — they work out of the box
# OpenStreetMap (hospital search) needs NO key either
